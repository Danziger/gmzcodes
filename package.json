{
  "name": "gmzcodes",
  "version": "1.0.0",
  "description": "👨‍💻 Dani Gamez's personal website PWA built using JavaScript, SCSS and HTML5.",
  "homepage": "https://gmzcodes.com",
  "license": "UNLICENSED",
  "author": {
    "name": "Daniel Gámez Franco",
    "url": "https://gmzcodes.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danziger/gmzcodes.git"
  },
  "bugs": {
    "url": "https://github.com/Danziger/gmzcodes/issues"
  },
  "main": "./src/app/main.js",
  "scripts": {
    "dev": "pnpm start",
    "start": "pnpm start:dev",
    "start:dev": "vite",
    "start:prod": "vite preview",
    "build": "pnpm build:prod",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build",
    "distclean": "rm -rf dist",
    "deploy": "pnpm distclean && pnpm build:prod && gh-pages -d dist",
    "eslint": "eslint src",
    "eslint:fix": "eslint --fix src",
    "stylelint": "stylelint src",
    "stylelint:fix": "stylelint --fix src",
    "nuke": "rm -rf node_modules && rm package-lock.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "pnpm": ">=10.30.0",
    "node": ">=22.0.0"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "meta-png": "^1.0.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "ejs": "^5.0.1",
    "eslint": "^10.0.3",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-import": "^2.32.0",
    "gh-pages": "^6.3.0",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.0.0",
    "vite": "^8.0.0",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 0.5%",
    "last 2 version",
    "Firefox ESR",
    "not dead",
    "iOS >= 9"
  ]
}